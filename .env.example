# ============================================================
# DSA AGENT AZURE MLOPS ENVIRONMENT EXAMPLE
# ============================================================
# COPY THIS FILE TO .env ONLY FOR LOCAL DEVELOPMENT.
# DO NOT COMMIT .env.

# ============================================================
# AZURE OPENAI SETTINGS
# ============================================================
AZURE_OPENAI_ENDPOINT=https://YOUR-AZURE-OPENAI-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=REPLACE_WITH_LOCAL_ONLY_VALUE
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini-dsa
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small-dsa

# ============================================================
# MODEL BEHAVIOR SETTINGS
# ============================================================
LLM_TEMPERATURE=0.0
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_K=4
RANDOM_SEED=42
